# ================== YOLO MODEL ==================
MODEL_PATH=D:/AI-for-drones/models/best.pt
CONFIDENCE=0.25

# ================== PERFORMANCE ==================
FRAME_DENSITY=3          # каждый n-й кадр будет прогоняться через YOLO
CAMERA_FPS_SLEEP=0.01    # задержка в потоке инференса
SHOW_WINDOWS=1           # показывать окна с видео

# ================== OUTPUT ==================
OUTPUT_DIR=results
WINDOW_CAMERA=Unity Drone Camera

# ================== UNITY STREAM ==================
VIDEO_UDP_PORT=5005      # порт для видеопотока из Unity
LIDAR_UDP_PORT=6006      # порт для LiDAR из Unity
CAMERA_FOV=90            # поле зрения камеры Unity в градусах

# ================== OPTIONAL DEFAULT SOURCES ==================
# (если захочешь тестировать без Unity, можно оставить пустым)
VIDEO_PATH=
PHOTO_PATH=
CAMERA_SOURCE=0